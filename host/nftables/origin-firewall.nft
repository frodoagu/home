#!/usr/sbin/nft -f
#
# Cloudflare-only origin firewall for the home-lab Raspberry Pi.
#
# WHY: all public services (*.agu.com.ar) are proxied through Cloudflare
# (charts/cloudflare-ddns, proxied: true). Legitimate internet traffic therefore
# only ever arrives from Cloudflare's edge IPs. Anyone hitting the Pi's public IP
# directly is bypassing Cloudflare (and any per-service rate-limit / auth that
# assumes CF-supplied headers). This drops inbound HTTP/HTTPS from any source
# that is NOT Cloudflare or the local LAN/cluster.
#
# WHY HERE (and not in Traefik): k3s's klipper servicelb SNATs every external
# connection to the node's CNI bridge (10.42.0.1) before Traefik sees it, so
# Traefik cannot tell Cloudflare from a direct hit. This rule runs at PREROUTING
# priority raw (-300), BEFORE klipper's dstnat (-100) and any POSTROUTING
# masquerade, so it still sees the REAL source IP and the ORIGINAL dport (80/443).
#
# SAFETY: this table ONLY polices tcp/80 and tcp/443. SSH (22), the k8s API
# (6443), and everything else are never touched, so a mistake here cannot lock
# you out of SSH. Roll back any time with:  nft delete table inet origin_fw
#
# ROUTER CAVEAT: this only works if your router preserves the internet source IP
# when port-forwarding 80/443 (plain DNAT). If it SNATs forwarded traffic to its
# own LAN IP, every external hit will appear as 192.168.0.x and be accepted by
# @local_v4 — i.e. the block is ineffective and you must filter at the router
# instead. VERIFY with the counters before trusting it (see docs/origin-firewall.md).
#
# Keep @cloudflare_v4 / @cloudflare_v6 in sync with https://www.cloudflare.com/ips/.

# Idempotent (re)load: ensure the table exists, drop it, recreate it fresh. This
# lets `nft -f` be run repeatedly (systemd ExecReload) without "set exists" errors.
add table inet origin_fw
delete table inet origin_fw

table inet origin_fw {
    set cloudflare_v4 {
        type ipv4_addr
        flags interval
        elements = {
            173.245.48.0/20, 103.21.244.0/22, 103.22.200.0/22,
            103.31.4.0/22,   141.101.64.0/18, 108.162.192.0/18,
            190.93.240.0/20, 188.114.96.0/20, 197.234.240.0/22,
            198.41.128.0/17, 162.158.0.0/15,  104.16.0.0/13,
            104.24.0.0/14,   172.64.0.0/13,   131.0.72.0/22
        }
    }

    set cloudflare_v6 {
        type ipv6_addr
        flags interval
        elements = {
            2400:cb00::/32, 2606:4700::/32, 2803:f800::/32,
            2405:b500::/32, 2405:8100::/32, 2a06:98c0::/29,
            2c0f:f248::/32
        }
    }

    # Sources that must always reach the ingress directly (not via Cloudflare):
    #   192.168.0.0/24  home LAN (the Pi is 192.168.0.100)
    #   10.0.0.0/8      k3s pod (10.42.0.0/16) + service (10.43.0.0/16) CIDRs
    #   127.0.0.0/8     loopback
    set local_v4 {
        type ipv4_addr
        flags interval
        elements = { 192.168.0.0/24, 10.0.0.0/8, 127.0.0.0/8 }
    }

    chain prerouting {
        type filter hook prerouting priority -300; policy accept;
        # Send ONLY inbound web traffic to the filter chain; all other ports
        # (SSH, 6443, ...) skip it entirely and are accepted by policy.
        tcp dport { 80, 443 } jump web_filter
    }

    chain web_filter {
        ip  saddr @cloudflare_v4 counter accept
        ip6 saddr @cloudflare_v6 counter accept
        ip  saddr @local_v4      counter accept
        ip6 saddr ::1            counter accept
        # Not Cloudflare, not local → a direct-to-origin bypass. Drop it.
        counter drop
    }
}
