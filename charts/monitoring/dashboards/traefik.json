{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["home", "traefik", "ingress", "http"],
  "title": "Traefik — Ingress",
  "uid": "traefik-ingress",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "DS_PROM", "label": "Datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0, "refresh": 1, "regex": "" }
    ]
  },
  "panels": [
    { "type": "row", "title": "Traffic", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },
    {
      "title": "Requests/s by entrypoint", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "fillOpacity": 15 } }, "overrides": [] },
      "targets": [ { "expr": "sum by(entrypoint)(rate(traefik_entrypoint_requests_total[5m]))", "legendFormat": "{{entrypoint}}", "refId": "A" } ]
    },
    {
      "title": "Requests/s by service", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [ { "expr": "sum by(service)(rate(traefik_service_requests_total[5m]))", "legendFormat": "{{service}}", "refId": "A" } ]
    },
    {
      "title": "Status codes", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [ { "expr": "sum by(code)(rate(traefik_service_requests_total[5m]))", "legendFormat": "{{code}}", "refId": "A" } ]
    },

    { "type": "row", "title": "Latency & Errors", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "collapsed": false },
    {
      "title": "Latency (p50 / p95 / p99)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le)(rate(traefik_service_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by(le)(rate(traefik_service_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by(le)(rate(traefik_service_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "title": "p95 latency by service", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by(le,service)(rate(traefik_service_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}", "refId": "A" } ]
    },

    { "type": "row", "title": "Health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }, "collapsed": false },
    {
      "title": "5xx error rate", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "fillOpacity": 30 } }, "overrides": [] },
      "targets": [ { "expr": "sum by(service)(rate(traefik_service_requests_total{code=~\"5..\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" } ]
    },
    {
      "title": "Open connections", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "expr": "sum by(entrypoint)(traefik_open_connections)", "legendFormat": "{{entrypoint}}", "refId": "A" } ]
    },
    {
      "title": "Config reload OK", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 19 },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "OK", "color": "green" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [ { "expr": "traefik_config_last_reload_success", "refId": "A" } ]
    }
  ]
}
