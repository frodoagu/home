{
  "uid": "victoria-logs",
  "title": "VictoriaLogs \u2014 Explorer",
  "tags": [
    "home",
    "logs",
    "victorialogs"
  ],
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "filter",
        "label": "LogsQL filter",
        "type": "textbox",
        "query": "*",
        "current": {
          "text": "*",
          "value": "*"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Logs in range",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "VictoriaLogs"
          },
          "expr": "$filter | stats count() total",
          "queryType": "stats"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Namespaces logging",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "VictoriaLogs"
          },
          "expr": "$filter | stats by (kubernetes.pod_namespace) count() | stats count() namespaces",
          "queryType": "stats"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log volume by namespace",
      "description": "Per-bucket log counts (LogsQL /select/logsql/hits), broken down by pod namespace.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "VictoriaLogs"
          },
          "expr": "$filter",
          "queryType": "hits",
          "field": "kubernetes.pod_namespace"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 0,
            "pointSize": 1,
            "showPoints": "never"
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error-ish log volume by namespace",
      "description": "Logs matching the word \"error\" within the current filter, by namespace.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "VictoriaLogs"
          },
          "expr": "$filter error",
          "queryType": "hits",
          "field": "kubernetes.pod_namespace"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 0,
            "pointSize": 1,
            "showPoints": "never"
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent logs",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "VictoriaLogs"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 13
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "VictoriaLogs"
          },
          "expr": "$filter",
          "queryType": "instant",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
