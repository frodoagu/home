# Helm dependency artifacts (fetched at sync time by ArgoCD / `helm dependency build`)
charts/*/charts/
charts/*/Chart.lock

# Cluster credentials – never commit
kubeconfig
*.kubeconfig

# Secret material – never commit (critical now that this repo can go public).
# The sealed-secrets controller private key decrypts EVERY committed SealedSecret.
sealed-secrets-key*.yaml
*.backup.yaml
*.key
*.pem
*.env
.env
esphome/secrets.yaml
